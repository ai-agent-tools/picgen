{
  "name": "@ai-agent-tools/picgen",
  "version": "0.1.0-alpha.10",
  "description": "A lightweight image generation connector for AI agents.",
  "type": "module",
  "bin": {
    "picgen": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skills",
    "docs",
    "examples",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "npm run sync-version && tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "sync-version": "node scripts/sync-version.mjs",
    "version": "npm run sync-version && git add src/version.ts package.json package-lock.json"
  },
  "keywords": [
    "agent",
    "image-generation",
    "openai",
    "gemini",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "commander": "^13.1.0",
    "dotenv": "^17.4.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
